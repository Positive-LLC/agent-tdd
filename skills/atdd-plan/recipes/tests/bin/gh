#!/usr/bin/env bash
# Poison `gh` for the Phase-1 recipe tests. The planning recipes must never call
# gh in the inner flow; if one does, this records it and fails loudly so the
# test catches the regression. (Setup also puts a fresh poison gh on PATH; this
# checked-in copy is the fallback / documents intent.)
printf 'POISON: gh called in inner flow: %s\n' "$*" >> "${GH_POISON_LOG:-/dev/stderr}"
exit 1
